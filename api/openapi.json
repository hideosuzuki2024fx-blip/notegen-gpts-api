{
  "openapi": "3.0.1",
  "info": {
    "title": "NoteGen GitHub API",
    "version": "1.0.0",
    "description": "API for listing and managing note articles in the NoteGenerator GitHub repository."
  },
  "paths": {
    "/api/github/list": {
      "get": {
        "summary": "List files in the NoteGenerator repository",
        "parameters": [
          {
            "name": "path",
            "in": "query",
            "description": "Path to list within the repository (e.g., articles/)",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with list of files",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": { "type": "string" },
                      "path": { "type": "string" },
                      "download_url": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
